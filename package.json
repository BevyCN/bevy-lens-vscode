{
  "name": "bevy-lens",
  "displayName": "Bevy Lens",
  "description": "A semantic Bevy ECS registry and explorer with docstring previews for VS Code.",
  "version": "0.1.28",
  "publisher": "bevycn",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BevyCN/bevy-lens-vscode"
  },
  "homepage": "https://bevycn.com/",
  "categories": [
    "Visualization",
    "Linters"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bevy-lens-sidebar",
          "title": "Bevy Lens",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "bevy-lens-sidebar": [
        {
          "id": "bevyGlobalRegistry",
          "name": "BEVY GLOBAL REGISTRY",
          "visibility": "visible"
        },
        {
          "id": "bevySemanticExplorer",
          "name": "BEVY SEMANTIC EXPLORER",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "bevy-lens.refresh",
        "title": "Refresh Bevy Lens",
        "icon": "$(refresh)"
      },
      {
        "command": "bevy-lens.search",
        "title": "Search Bevy Elements...",
        "icon": "$(search)"
      },
      {
        "command": "bevy-lens.resetSearch",
        "title": "Clear Search Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "bevy-lens.explorer.newFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "bevy-lens.explorer.newFileFromTemplate",
        "title": "New File from Template...",
        "icon": "$(file-code)"
      },
      {
        "command": "bevy-lens.explorer.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "bevy-lens.explorer.rename",
        "title": "Rename..."
      },
      {
        "command": "bevy-lens.explorer.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "bevy-lens.explorer.reveal",
        "title": "Reveal in Explorer View"
      },
      {
        "command": "bevy-lens.changeSortOrder",
        "title": "Change Sort Order...",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "bevy-lens.openScheduleVisualizer",
        "title": "Open Schedule Visualizer",
        "icon": "$(graph)"
      },
      {
        "command": "bevy-lens.explorer.openToSide",
        "title": "Open to the Side"
      },
      {
        "command": "bevy-lens.explorer.openWith",
        "title": "Open With..."
      },
      {
        "command": "bevy-lens.explorer.openInTerminal",
        "title": "Open in Integrated Terminal"
      },
      {
        "command": "bevy-lens.explorer.cut",
        "title": "Cut",
        "icon": "$(edit)"
      },
      {
        "command": "bevy-lens.explorer.copy",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "bevy-lens.explorer.paste",
        "title": "Paste",
        "icon": "$(clippy)"
      },
      {
        "command": "bevy-lens.explorer.selectForCompare",
        "title": "Select for Compare"
      },
      {
        "command": "bevy-lens.explorer.compareWithSelected",
        "title": "Compare with Selected"
      },
      {
        "command": "bevy-lens.explorer.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "bevy-lens.explorer.copyRelativePath",
        "title": "Copy Relative Path"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "bevy-lens.search",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1"
        },
        {
          "command": "bevy-lens.resetSearch",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1.5"
        },
        {
          "command": "bevy-lens.changeSortOrder",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1.8"
        },
        {
          "command": "bevy-lens.explorer.newFile",
          "when": "view == bevySemanticExplorer",
          "group": "navigation@1"
        },
        {
          "command": "bevy-lens.explorer.newFileFromTemplate",
          "when": "view == bevySemanticExplorer",
          "group": "navigation@1.5"
        },
        {
          "command": "bevy-lens.explorer.newFolder",
          "when": "view == bevySemanticExplorer",
          "group": "navigation@2"
        },
        {
          "command": "bevy-lens.refresh",
          "when": "view == bevyGlobalRegistry || view == bevySemanticExplorer",
          "group": "navigation@3"
        },
        {
          "command": "bevy-lens.openScheduleVisualizer",
          "when": "view == bevyGlobalRegistry || view == bevySemanticExplorer",
          "group": "navigation@2.5"
        }
      ],
      "view/item/context": [
        {
          "command": "bevy-lens.explorer.newFile",
          "when": "view == bevySemanticExplorer && (viewItem == directory || !viewItem)",
          "group": "1_new@1"
        },
        {
          "command": "bevy-lens.explorer.newFileFromTemplate",
          "when": "view == bevySemanticExplorer && (viewItem == directory || !viewItem)",
          "group": "1_new@2"
        },
        {
          "command": "bevy-lens.explorer.newFolder",
          "when": "view == bevySemanticExplorer && (viewItem == directory || !viewItem)",
          "group": "1_new@3"
        },
        {
          "command": "bevy-lens.explorer.rename",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "2_modify"
        },
        {
          "command": "bevy-lens.explorer.delete",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "3_delete"
        },
        {
          "command": "bevy-lens.explorer.reveal",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "4_reveal"
        },
        {
          "command": "bevy-lens.explorer.openToSide",
          "when": "view == bevySemanticExplorer && viewItem == file",
          "group": "0_open@1"
        },
        {
          "command": "bevy-lens.explorer.openWith",
          "when": "view == bevySemanticExplorer && viewItem == file",
          "group": "0_open@2"
        },
        {
          "command": "bevy-lens.explorer.openInTerminal",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file || !viewItem)",
          "group": "0_open@3"
        },
        {
          "command": "bevy-lens.explorer.cut",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "5_clipboard@1"
        },
        {
          "command": "bevy-lens.explorer.copy",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "5_clipboard@2"
        },
        {
          "command": "bevy-lens.explorer.paste",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file || !viewItem) && bevyLens.clipboardHasData",
          "group": "5_clipboard@3"
        },
        {
          "command": "bevy-lens.explorer.selectForCompare",
          "when": "view == bevySemanticExplorer && viewItem == file",
          "group": "6_compare@1"
        },
        {
          "command": "bevy-lens.explorer.compareWithSelected",
          "when": "view == bevySemanticExplorer && viewItem == file && bevyLens.compareSourceSelected",
          "group": "6_compare@2"
        },
        {
          "command": "bevy-lens.explorer.copyPath",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "7_path@1"
        },
        {
          "command": "bevy-lens.explorer.copyRelativePath",
          "when": "view == bevySemanticExplorer && (viewItem == directory || viewItem == file)",
          "group": "7_path@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "bevy-lens.explorer.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.cut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.delete",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.rename",
        "key": "f2",
        "mac": "enter",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.copyPath",
        "key": "shift+alt+c",
        "mac": "shift+cmd+c",
        "when": "view == bevySemanticExplorer && !inputFocus"
      },
      {
        "command": "bevy-lens.explorer.copyRelativePath",
        "key": "ctrl+k ctrl+shift+c",
        "mac": "cmd+k cmd+shift+c",
        "when": "view == bevySemanticExplorer && !inputFocus"
      }
    ],
    "configuration": {
      "title": "Bevy Lens",
      "properties": {
        "bevyLens.excludePaths": {
          "type": "array",
          "default": [
            "**/target/**",
            "**/.git/**"
          ],
          "description": "Paths to exclude when scanning for Bevy assets."
        },
        "bevyLens.enableConflictDiagnostics": {
          "type": "boolean",
          "default": false,
          "description": "Enable static query read/write conflict warnings for parallel systems."
        },
        "bevyLens.sortBy": {
          "type": "string",
          "default": "alphabetical",
          "enum": [
            "alphabetical",
            "position"
          ],
          "enumDescriptions": [
            "Sort elements alphabetically by name (A-Z)",
            "Sort elements by their line position in the source file"
          ],
          "description": "Specify how Bevy registry elements should be sorted in the tree views."
        },
        "bevyLens.customRenderGraphSchedules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "User-defined custom render schedules (e.g. CoreCustom3D) to be classified under Render Graph systems."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "watch-tests": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5",
    "eslint": "^8.36.0",
    "@typescript-eslint/parser": "^5.55.0",
    "@typescript-eslint/eslint-plugin": "^5.55.0"
  }
}
