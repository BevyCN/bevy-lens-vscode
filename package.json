{
  "name": "bevy-lens",
  "displayName": "Bevy Lens",
  "description": "Bevy 0.19 semantic navigation, registry, diagnostics, and visualizers for VS Code.",
  "version": "0.2.0",
  "publisher": "bevycn",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BevyCN/bevy-lens-vscode"
  },
  "homepage": "https://bevycn.com/",
  "categories": [
    "Visualization",
    "Linters"
  ],
  "icon": "resources/icon.png",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bevy-lens-sidebar",
          "title": "Bevy Lens",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "bevy-lens-sidebar": [
        {
          "id": "bevyGlobalRegistry",
          "name": "BEVY GLOBAL REGISTRY",
          "visibility": "visible"
        }
      ],
      "explorer": [
        {
          "id": "bevySemanticExplorer",
          "name": "BEVY SEMANTICS",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "bevy-lens.refresh",
        "title": "Refresh Bevy Lens",
        "icon": "$(refresh)"
      },
      {
        "command": "bevy-lens.search",
        "title": "Search Bevy Elements...",
        "icon": "$(search)"
      },
      {
        "command": "bevy-lens.resetSearch",
        "title": "Clear Search Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "bevy-lens.changeSortOrder",
        "title": "Change Sort Order...",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "bevy-lens.openScheduleVisualizer",
        "title": "Open Schedule Visualizer",
        "icon": "$(graph)"
      },
      {
        "command": "bevy-lens.findReferences",
        "title": "Find Bevy References",
        "icon": "$(references)"
      },
      {
        "command": "bevy-lens.revealInSemanticExplorer",
        "title": "Reveal in Bevy Semantic Explorer",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "bevy-lens.revealInSemanticExplorer",
          "group": "navigation",
          "when": "resourceExtname == .rs || resourceExtname == .wgsl || resourceExtname == .wesl"
        }
      ],
      "explorer/context": [
        {
          "command": "bevy-lens.revealInSemanticExplorer",
          "group": "navigation",
          "when": "resourceExtname == .rs || resourceExtname == .wgsl || resourceExtname == .wesl"
        }
      ],
      "editor/context": [
        {
          "command": "bevy-lens.revealInSemanticExplorer",
          "group": "navigation@1",
          "when": "resourceExtname == .rs || resourceExtname == .wgsl || resourceExtname == .wesl"
        },
        {
          "command": "bevy-lens.findReferences",
          "group": "navigation@2",
          "when": "editorTextFocus && resourceLangId == rust"
        }
      ],
      "view/title": [
        {
          "command": "bevy-lens.search",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1"
        },
        {
          "command": "bevy-lens.resetSearch",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1.5"
        },
        {
          "command": "bevy-lens.changeSortOrder",
          "when": "view == bevyGlobalRegistry",
          "group": "navigation@1.8"
        },
        {
          "command": "bevy-lens.openScheduleVisualizer",
          "when": "view == bevyGlobalRegistry || view == bevySemanticExplorer",
          "group": "navigation@2.5"
        },
        {
          "command": "bevy-lens.refresh",
          "when": "view == bevyGlobalRegistry || view == bevySemanticExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "bevy-lens.findReferences",
          "when": "viewItem == bevyElement",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Bevy Lens",
      "properties": {
        "bevyLens.excludePaths": {
          "type": "array",
          "default": [
            "**/target/**",
            "**/.git/**",
            "**/node_modules/**"
          ],
          "description": "Glob patterns excluded from Bevy semantic indexing."
        },
        "bevyLens.enableConflictDiagnostics": {
          "type": "boolean",
          "default": false,
          "description": "Enable static query read/write conflict warnings for parallel systems."
        },
        "bevyLens.sortBy": {
          "type": "string",
          "default": "alphabetical",
          "enum": [
            "alphabetical",
            "position"
          ],
          "enumDescriptions": [
            "Sort elements alphabetically by name (A-Z)",
            "Sort elements by their line position in the source file"
          ],
          "description": "Specify how Bevy registry elements should be sorted in the tree views."
        },
        "bevyLens.customRenderGraphSchedules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "User-defined custom render schedules (e.g. CoreCustom3D) to be classified under Render Graph systems."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "watch-tests": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5",
    "eslint": "^8.36.0",
    "@typescript-eslint/parser": "^5.55.0",
    "@typescript-eslint/eslint-plugin": "^5.55.0"
  }
}
